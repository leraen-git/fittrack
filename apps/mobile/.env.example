# Copy this file to .env and fill in all values.
# NEVER commit .env — it is gitignored.

# API URL — local: http://localhost:3000, prod: https://api.yourapp.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# Clerk publishable key (https://dashboard.clerk.com)
# Required in production. Leave blank in dev to use server DEV_CLERK_ID fallback.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
